# ============================================================
# 環境変数テンプレート
# ============================================================
#
# ■ ローカル開発:
#   cp .env.example .env.local
#
# ■ セルフホスト (Docker):
#   cp .env.example .env.production
#   → POSTGRES_PASSWORD, JWT_SECRET, JWT_REFRESH_SECRET を変更
#   → docker compose up -d --build
#
# ============================================================

# --- データベース ---
# ローカル開発: supabase start で起動した PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# --- Supabase (ローカル開発用) ---
# supabase start 実行後にターミナルに表示される値を記載
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- 認証 ---
JWT_SECRET=local-dev-jwt-secret-change-in-production
JWT_REFRESH_SECRET=local-dev-jwt-refresh-secret-change-in-production

# --- アプリケーション ---
FRONTEND_URL=http://localhost:3000
PORT=4000
NODE_ENV=development

# ============================================================
# セルフホスト (Docker) 用の設定
# docker compose で使用する場合は以下を設定してください
# ============================================================

# PostgreSQL のパスワード（必ず変更してください）
POSTGRES_PASSWORD=change-me-to-a-strong-password
